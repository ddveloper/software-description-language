{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/software-description-language/spec/layer_logic/entry-point.schema.json",
  "title": "SDL EntryPoint",
  "description": "An EntryPoint is any interface through which the outside world initiates activity in this service. It crosses the Container boundary inward (layer_logic), triggering an Operation. EntryPoints are the DL Trigger concept in SDL. At layer_service, ServiceFlow steps may reference EntryPoints via entry_point_ref to link cross-service flows to their intra-service handlers.",
  "type": "object",
  "dl": {
    "profile": "software",
    "version": "0.1",
    "concepts": ["Trigger"],
    "layer": "semantic",
    "layer_ref": "layer_logic",
    "notes": "An EntryPoint crosses the service (Container) boundary from outside to inside, causing an Operation (Unit) to run. EntryPoints are the inbound side of inter-Container Connects whose outbound side is a Dependency in another service."
  },
  "required": ["id", "kind", "label", "operation_ref"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique kebab-case identifier for this entry point within the service.",
      "pattern": "^[a-z0-9][a-z0-9-_]*[a-z0-9]$",
      "examples": ["create-order-route", "payment-completed-consumer", "nightly-cleanup-job"]
    },
    "kind": {
      "type": "string",
      "description": "The category of entry point. See stdlib/entry-point-kinds.json for ai_hint per kind.",
      "enum": [
        "http-route",
        "event-consumer",
        "scheduled-job",
        "grpc-method",
        "graphql-resolver",
        "cli-command",
        "startup-hook",
        "shutdown-hook",
        "custom"
      ]
    },
    "label": {
      "type": "string",
      "description": "Human-readable name for this entry point.",
      "examples": ["POST /orders", "Consume payment.completed", "Nightly Cleanup Job"]
    },
    "description": {
      "type": "string",
      "description": "What arrives here and what this entry point is responsible for receiving."
    },
    "operation_ref": {
      "type": "string",
      "description": "The id of the Operation that handles this entry point. Must reference a valid operation id in operations.sdl.json.",
      "examples": ["create-order", "handle-payment-completed"]
    },
    "http": {
      "type": "object",
      "description": "HTTP route details. Required when kind is 'http-route'.",
      "required": ["method", "path"],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
        },
        "path": {
          "type": "string",
          "examples": ["/orders", "/orders/{id}", "/webhooks/stripe"]
        },
        "auth": {
          "type": "string",
          "enum": ["none", "jwt", "api-key", "mtls", "oauth2", "session", "custom"]
        },
        "middleware": {
          "type": "array",
          "items": { "type": "string" },
          "examples": [["authenticate", "validateBody", "rateLimitByUser"]]
        }
      }
    },
    "event": {
      "type": "object",
      "description": "Event consumer details. Required when kind is 'event-consumer'.",
      "required": ["topic"],
      "additionalProperties": false,
      "properties": {
        "topic":          { "type": "string", "examples": ["payment.completed", "order.created"] },
        "broker":         { "type": "string", "enum": ["kafka", "sqs", "rabbitmq", "pubsub", "nats", "redis", "custom"] },
        "consumer_group": { "type": "string", "examples": ["order-service-group"] },
        "idempotency":    { "type": "string", "enum": ["none", "deduplication-key", "database-check", "custom"] }
      }
    },
    "schedule": {
      "type": "object",
      "description": "Scheduled job details. Required when kind is 'scheduled-job'.",
      "required": ["cron"],
      "additionalProperties": false,
      "properties": {
        "cron":        { "type": "string", "examples": ["0 2 * * *", "*/5 * * * *"] },
        "timezone":    { "type": "string", "examples": ["UTC", "America/New_York"] },
        "description": { "type": "string", "examples": ["Every night at 2am UTC"] }
      }
    },
    "grpc": {
      "type": "object",
      "description": "gRPC method details. Required when kind is 'grpc-method'.",
      "required": ["service", "method"],
      "additionalProperties": false,
      "properties": {
        "service":   { "type": "string", "examples": ["OrderService"] },
        "method":    { "type": "string", "examples": ["CreateOrder", "GetOrder"] },
        "proto_ref": { "type": "string", "examples": ["./contracts/order.proto"] }
      }
    },
    "graphql": {
      "type": "object",
      "description": "GraphQL resolver details. Required when kind is 'graphql-resolver'.",
      "required": ["operation_type", "field"],
      "additionalProperties": false,
      "properties": {
        "operation_type": { "type": "string", "enum": ["query", "mutation", "subscription"] },
        "field":          { "type": "string", "examples": ["createOrder", "getOrder"] },
        "schema_ref":     { "type": "string", "examples": ["./contracts/schema.graphql"] }
      }
    },
    "input_shape_ref": {
      "type": "string",
      "description": "The id of the DataShape describing the payload that arrives at this entry point.",
      "examples": ["create-order-request", "payment-completed-event"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "examples": [["revenue-critical", "authenticated", "idempotent"]]
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
