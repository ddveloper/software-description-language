      { "name": "currency_code", "type": "string", "description": "3-letter ISO 4217 currency code." },
      { "name": "units", "type": "int64", "description": "Whole units of the amount." },
      { "name": "nanos", "type": "int32", "description": "Nano units (10^-9) of the amount." }
    ],
    "tags": ["value-object", "shared"]
  }
